{
  "name": "ideaapp-backend",
  "version": "0.5.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --out-dir dist",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "e2e:smoke": "node scripts/e2e-smoke.js",
    "e2e:reset": "node scripts/e2e-reset.js",
    "e2e:verify": "node scripts/e2e-runner.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@fastify/multipart": "^8.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "jsonwebtoken": "^9.0.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "prisma": "^5.22.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
