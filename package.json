{
  "name": "ideaapp-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.15.4"
  },
  "scripts": {
    "dev:backend": "pnpm --filter ideaapp-backend dev",
    "dev:merchant-web": "pnpm --filter ideaapp-merchant-web dev",
    "dev:mobile-app": "pnpm --filter rabtaone-mobile-app dev",
    "build:backend": "pnpm --filter ideaapp-backend build",
    "build:merchant-web": "pnpm --filter ideaapp-merchant-web build",
    "build:mobile-app": "pnpm --filter rabtaone-mobile-app build",
    "prisma:generate": "pnpm --filter ideaapp-backend prisma:generate",
    "prisma:migrate": "pnpm --filter ideaapp-backend prisma:migrate"
  }
}
